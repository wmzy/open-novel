    "drizzle-orm": "^0.45.2",
    "haze-ui": "^1.5.6",
    "hono": "^4.12.18",
    "pino": "^10.3.1",
    "pino-pretty": "^10.3.1",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^7.15.0",
